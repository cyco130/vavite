{
  "name": "vavite",
  "version": "6.1.0",
  "description": "vavite",
  "keywords": [
    "nextjs",
    "react",
    "ssr",
    "vite"
  ],
  "license": "MIT",
  "repository": "github:cyco130/vavite",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./types.d.ts"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "rm -rf dist && pnpm build",
    "test": "pnpm run /^test:/",
    "test:typecheck": "tsc -p tsconfig.json --noEmit",
    "test:lint": "eslint . --max-warnings 0 --ignore-pattern dist",
    "test:package": "publint"
  },
  "dependencies": {
    "http-proxy-3": "^1.23.2"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^7.0.0",
    "@types/node": "^20.19.37",
    "eslint": "^10.1.0",
    "publint": "^0.3.18",
    "tsdown": "0.21.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  },
  "peerDependencies": {
    "vite": "~7.3 || 8"
  }
}
